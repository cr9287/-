<view class="page-container">
  <view class="login-card">
    <view class="top-header">
      <view class="title-section">
        <view class="title">重置密码</view>
      </view>
    </view>
    
    <view class="divider-line"></view>
    <view class="text-title mb-20">账号验证</view>
    
    <!-- Account -->
    <view class="form-item">
      <view class="form-label">
        <text>用户名</text>
        <text class="required">*</text>
      </view>
      <input class="input form-input" placeholder="请输入用户名" value="{{account}}" bindinput="onAccount" />
    </view>

    <!-- Phone -->
    <view class="form-item">
      <view class="form-label">
        <text>手机号</text>
        <text class="required">*</text>
      </view>
      <input class="input form-input" type="number" placeholder="请输入注册时的手机号" value="{{phone}}" bindinput="onPhone" />
    </view>

    <view class="divider-line"></view>
    <view class="text-title mb-20">设置新密码</view>

    <!-- New Password -->
    <view class="form-item">
      <view class="form-label">
        <text>新密码</text>
        <text class="required">*</text>
      </view>
      <view class="input-wrapper">
        <input class="input form-input" password="{{!newPasswordVisible}}" placeholder="请输入新密码(至少6位)" value="{{newPassword}}" bindinput="onNewPassword" />
        <view class="password-toggle" bindtap="toggleNewPasswordVisibility">{{newPasswordVisible ? '隐藏' : '显示'}}</view>
      </view>
    </view>

    <!-- Confirm Password -->
    <view class="form-item">
      <view class="form-label">
        <text>确认密码</text>
        <text class="required">*</text>
      </view>
      <view class="input-wrapper">
        <input class="input form-input" password="{{!confirmPasswordVisible}}" placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPassword" />
        <view class="password-toggle" bindtap="toggleConfirmPasswordVisibility">{{confirmPasswordVisible ? '隐藏' : '显示'}}</view>
      </view>
    </view>

    <view class="actions">
      <button class="login-btn" bindtap="submitReset" loading="{{loading}}" disabled="{{loading}}">确认重置</button>
    </view>

    <view class="footer-section">
      <navigator url="/pages/userLogin/userLogin" open-type="redirect" class="footer-link">返回登录</navigator>
    </view>
  </view>
</view>
