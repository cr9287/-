<view class="consumptions-page">


  <!-- 查询和排序栏 -->
  <view class="filter-bar">
    <view class="search-container">
      <input 
        class="search-input" 
        placeholder="搜索球台" 
        bindinput="onSearchInput"
        value="{{searchKeyword}}"
      />
      <view class="time-filter" bindtap="showSortMenu">
        <text class="filter-text">{{sortText}}</text>
        <text class="filter-icon">{{sortIcon}}</text>
      </view>
    </view>
  </view>

  <!-- 排序菜单 -->
  <view wx:if="{{showSortMenu}}" class="sort-menu">
    <view class="sort-item" bindtap="sortByTime">按时间排序</view>
    <view class="sort-item" bindtap="sortByTable">按球桌排序</view>
    <view class="sort-item" bindtap="sortByAmount">按金额排序</view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!consumptions.length}}" class="empty-state">
    <view class="empty-icon"></view>
    <view class="empty-title">暂无历史消费记录</view>
    <view class="empty-subtitle">快去充值或开台体验吧</view>
    <view class="empty-actions">
      <button class="empty-btn recharge-btn" bindtap="goWallet">去充值</button>
      <button class="empty-btn home-btn" bindtap="goHome">去开台</button>
    </view>
  </view>

  <!-- 消费记录列表 -->
  <view wx:else class="consumptions-list">
    <block wx:for="{{consumptions}}" wx:key="id">
      <view class="cons-card" bindtap="showConsumptionDetail" data-id="{{item.id}}">
        <!-- 卡片顶部：时间 + 类型 -->
        <view class="card-header">
          <text class="cons-time">{{item.periodText}}</text>
          <text class="cons-type">{{item.type === 'recharge' ? '充值' : '消费'}}</text>
        </view>
        
        <!-- 卡片主体：金额信息 -->
        <view class="card-body">
          <view class="amount-section">
            <text class="amount-label">{{item.consumptionTypeText}}</text>
            <text class="cons-amount {{item.type === 'recharge' ? 'recharge' : 'consumption'}}">{{item.amountText}}</text>
          </view>
          
          <!-- 附加信息 -->
          <view class="additional-info">
            <text class="table-text" wx:if="{{item.tableText}}">{{item.tableText}}</text>
            <text class="duration-text" wx:if="{{item.minutesText}}">{{item.minutesText}}</text>
            <text class="payment-text" wx:if="{{item.paymentMethodText}}">{{item.paymentMethodText}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{consumptions.length}}" class="page-footer">
    <text class="stat-item">共 {{totalCount}} 条记录</text>
  </view>
</view>