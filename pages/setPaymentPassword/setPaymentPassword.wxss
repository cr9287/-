.page-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

.card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.08);
  padding: 48rpx 40rpx;
  width: 90%;
  max-width: 700rpx;
  box-sizing: border-box;
}

.text-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 48rpx;
  color: #333;
  text-align: center;
}

/* 提示信息区域 */
.tip-section {
  background: linear-gradient(135deg, #f0f7ff 0%, #e6f4ff 100%);
  border: 2rpx solid #1677ff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: flex-start;
}

.tip-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  color: #1677ff;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1677ff;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #3b82f6;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

/* 表单区域 */
.form-section {
  margin-bottom: 48rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.password-input {
  width: 100%;
  height: 96rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 36rpx;
  letter-spacing: 8rpx;
  background: #f9f9f9;
  box-sizing: border-box;
  transition: all 0.3s;
}

.password-input:focus {
  border-color: #1677ff;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.1);
}

/* 错误提示 */
.error-tip {
  background: #fff2f0;
  border: 2rpx solid #ffccc7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 24rpx;
}

.error-text {
  font-size: 26rpx;
  color: #ff4d4f;
}

/* 成功提示 */
.success-tip {
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 24rpx;
}

.success-text {
  font-size: 26rpx;
  color: #52c41a;
  font-weight: 500;
}

/* 操作按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
}

.btn-primary[disabled] {
  background: #ccc;
  box-shadow: none;
}

.btn-primary:active:not([disabled]) {
  transform: scale(0.98);
}

.btn-cancel {
  height: 96rpx;
  background: #fff;
  color: #666;
  border: 2rpx solid #e5e5e5;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.btn-cancel:active {
  background: #f5f5f5;
}
