<view class="page-wrap">
  <view class="card">
    <view class="text-title">新建用户</view>
    <view class="form-item">
      <view class="label">账号</view>
      <input class="input" placeholder="请输入账号" value="{{account}}" bindinput="onAccount" />
    </view>
    <view class="form-item">
      <view class="label">密码</view>
      <view class="input-wrapper">
        <input class="input" password="{{!passwordVisible}}" placeholder="请输入密码" value="{{password}}" bindinput="onPassword" />
        <view class="eye-icon" bindtap="togglePasswordVisibility">
          {{passwordVisible ? '隐藏' : '显示'}}
        </view>
      </view>
    </view>
    <view class="form-item">
      <view class="label">昵称</view>
      <input class="input" placeholder="请输入昵称（选填）" value="{{name}}" bindinput="onName" />
    </view>
    <view class="form-item">
      <view class="label">手机号</view>
      <input class="input" type="number" placeholder="请输入手机号（选填）" value="{{phone}}" bindinput="onPhone" />
    </view>
    <view class="actions">
      <button class="btn-primary" bindtap="create" loading="{{loading}}" disabled="{{loading}}">创建</button>
    </view>
  </view>
</view>
