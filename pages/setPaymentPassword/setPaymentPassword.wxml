<view class="page-wrap">
  <view class="card">
    <view class="text-title">设置支付密码</view>
    
    <!-- 提示信息 -->
    <view class="tip-section">
      <view class="tip-icon">ℹ️</view>
      <view class="tip-content">
        <view class="tip-title">支付密码说明</view>
        <view class="tip-text">• 支付密码为 6 位数字</view>
        <view class="tip-text">• 用于充值时验证身份</view>
        <view class="tip-text">• 请勿与登录密码相同</view>
      </view>
    </view>
    
    <!-- 密码输入表单 -->
    <view class="form-section">
      <view class="form-item">
        <view class="label">设置支付密码</view>
        <input 
          class="password-input" 
          type="password" 
          placeholder="请输入 6 位数字密码" 
          maxlength="6" 
          value="{{newPaymentPassword}}" 
          bindinput="onNewPaymentPasswordInput"
          password
        />
      </view>
      
      <view class="form-item">
        <view class="label">确认支付密码</view>
        <input 
          class="password-input" 
          type="password" 
          placeholder="请再次输入密码" 
          maxlength="6" 
          value="{{confirmPaymentPassword}}" 
          bindinput="onConfirmPaymentPasswordInput"
          password
        />
      </view>
      
      <!-- 错误提示 -->
      <view class="error-tip" wx:if="{{passwordError}}">
        <text class="error-text">{{passwordError}}</text>
      </view>
      
      <!-- 成功提示 -->
      <view class="success-tip" wx:if="{{passwordSuccess}}">
        <text class="success-text">密码设置成功</text>
      </view>
    </view>
    
    <!-- 操作按钮 -->
    <view class="actions">
      <button 
        class="btn-primary" 
        bindtap="setPaymentPassword" 
        disabled="{{!newPaymentPassword || !confirmPaymentPassword || saving}}"
        loading="{{saving}}"
      >
        确认设置
      </button>
      <button class="btn-cancel" bindtap="goBack">取消</button>
    </view>
  </view>
</view>
