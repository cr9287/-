/**app.wxss**/
/* 微信原生风格 - 蓝色加白色主题 */
page { background: #f5f5f5; color: #333333; font-size: 28rpx; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; }

/* 卡片与阴影、圆角统一规范 */
.card { background: #ffffff; border-radius: 12rpx; box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06); padding: 24rpx; margin-bottom: 20rpx; }

/* 文字分级 */
.text-title { font-size: 36rpx; font-weight: 600; color: #333333; }
.text-body { font-size: 28rpx; color: #666666; }
.text-sub { font-size: 24rpx; color: #999999; }
.text-primary { color: #1677ff; }

/* 按钮样式 - 微信原生风格 */
.btn { display: block; width: 100%; height: 80rpx; line-height: 80rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 500; text-align: center; transition: all 0.2s; margin-bottom: 20rpx; }
.btn-primary { background-color: #1677ff; color: #ffffff; border: none; }
.btn-primary:active { background-color: #0958d9; opacity: 0.8; }
.btn-secondary { background-color: #ffffff; color: #1677ff; border: 2rpx solid #1677ff; }
.btn-secondary:active { background-color: #f0f6ff; opacity: 0.8; }
.btn-mini { width: auto; height: 64rpx; line-height: 64rpx; padding: 0 32rpx; font-size: 24rpx; border-radius: 32rpx; }

/* 状态标签（胶囊形） - 微信原生风格 */
.tag { font-size: 22rpx; padding: 8rpx 20rpx; border-radius: 20rpx; display: inline-block; font-weight: 400; }
.tag-primary { background-color: #e6f4ff; color: #1677ff; }
.tag-success { background-color: #f6ffed; color: #52c41a; }
.tag-warning { background-color: #fff7e6; color: #faad14; }
.tag-danger { background-color: #fff1f0; color: #f5222d; }

/* 通用边距 */
.page-container { padding: 0 24rpx; min-height: 100vh; box-sizing: border-box; }
.section { margin: 20rpx 0; }
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mx-20 { margin: 0 20rpx; }

/* 输入框规范 - 微信原生风格 */
.input { background: #ffffff; border: 2rpx solid #e5e5e5; border-radius: 8rpx; padding: 0 24rpx; height: 88rpx; line-height: 88rpx; font-size: 28rpx; color: #333333; box-sizing: border-box; }
.input:focus { border-color: #1677ff; outline: none; }
.input-placeholder { color: #bfbfbf; }

/* 底部链接与说明 */
.footer { padding: 32rpx 0 48rpx; text-align: center; }
.link { font-size: 24rpx; color: #1677ff; text-decoration: none; }
.link:active { color: #0958d9; }

/* 记住密码行（通用表单项） */
.remember-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.remember-text { font-size: 24rpx; color: #666666; }

/* 价格类文字 */
.font-din { font-family: DINAlternate-Bold, "DIN Condensed", "DIN Alternate", "Helvetica Neue", sans-serif; }
.price { color: #ff4d4f; font-weight: 600; font-family: DINAlternate-Bold, "DIN Condensed", "DIN Alternate", "Helvetica Neue", sans-serif; }
.price-large { font-size: 36rpx; }
.price-symbol { font-size: 0.8em; margin-right: 2rpx; }

/* 卡片变体 */
.card-primary {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.3);
}
.card-primary .text-body, .card-primary .text-sub {
  color: rgba(255, 255, 255, 0.8);
}

/* 布局工具类 */
.flex { display: flex; }
.flex-column { flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-start { display: flex; align-items: center; justify-content: flex-start; }
.flex-end { display: flex; align-items: center; justify-content: flex-end; }
.flex-wrap { flex-wrap: wrap; }
.gap-10 { gap: 10rpx; }
.gap-20 { gap: 20rpx; }

/* 间距工具类 */
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }
.m-20 { margin: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-30 { margin-bottom: 30rpx; }

/* 文本工具类 */
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-white { color: #ffffff; }
.text-bold { font-weight: 600; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 40rpx; }
.text-danger { color: #f5222d; }
.text-success { color: #52c41a; }
.text-warning { color: #faad14; }

/* 背景工具类 */
.bg-white { background-color: #ffffff; }
.bg-primary { background-color: #1677ff; }

/* 按钮变体 */
.btn-outline-white {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}
.btn-outline-white:active {
  background: rgba(255, 255, 255, 0.3);
}

.btn-white {
  background: #ffffff;
  color: #1677ff;
  border: none;
}
.btn-white:active {
  background: #f0f0f0;
}

/* 阴影效果 */
.shadow-sm { box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06); }
.shadow-md { box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1); }


/* 顶部导航栏与底部导航 - 微信原生风格 */
.topbar { height: 88rpx; background: #ffffff; color: #333333; display:flex; align-items:center; justify-content:space-between; padding: 0 24rpx; border-bottom: 2rpx solid #e5e5e5; }
.topbar-title { font-size: 32rpx; font-weight: 600; }
.topbar-btn { color: #1677ff; font-size: 28rpx; }

.tabbar { position: fixed; bottom: 0; left: 0; right: 0; height: 120rpx; background: #ffffff; border-top: 2rpx solid #e5e5e5; display:flex; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06); padding-bottom: env(safe-area-inset-bottom); }
.tab-item { flex:1; display:flex; flex-direction: column; align-items:center; justify-content:center; color:#999999; }
.tab-icon { font-size: 44rpx; margin-bottom: 8rpx; }
.tab-text { font-size: 24rpx; }
.tab-item.active { color: #1677ff; }

/* 通用容器 */
.container { min-height: 100%; box-sizing: border-box; }

/* 分割线 */
.divider { height: 20rpx; background-color: #f5f5f5; margin: 20rpx 0; }
.divider-line { height: 2rpx; background-color: #e5e5e5; margin: 20rpx 0; }

/* 列表项样式 */
.list-item { background: #ffffff; padding: 24rpx; display: flex; align-items: center; justify-content: space-between; border-bottom: 2rpx solid #f0f0f0; }
.list-item:last-child { border-bottom: none; }
.list-item-title { font-size: 28rpx; color: #333333; }
.list-item-value { font-size: 28rpx; color: #666666; }

/* 加载状态 */
.loading { display: flex; align-items: center; justify-content: center; padding: 40rpx; color: #666666; font-size: 24rpx; }

/* 空状态 */
.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80rpx 20rpx; color: #999999; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; }
