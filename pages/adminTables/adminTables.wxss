page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 0;
}

/* 页面容器 */
.admin-tables {
  padding: 0;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 顶部导航栏 */
.nav-bar {
  background: #fff;
  padding: 0 20rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e5e5e5;
  position: relative;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}

.nav-title {
  flex: 1;
  text-align: center;
}

.title-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder {
  width: 60rpx;
}

/* 页面标题区域 */
.page-header-row {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.page-subtitle {
  font-size: 26rpx;
  color: #666;
}

/* 批量操作区域 */
.batch-operations {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.batch-info {
  flex: 1;
}

.batch-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.batch-select-all {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.batch-delete {
  background: #ff4d4f;
  color: #fff;
  border: 1rpx solid #ff4d4f;
}

.batch-cancel {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.batch-btn:active {
  transform: scale(0.95);
}

/* 进入批量模式按钮 */
.enter-batch-mode {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
  display: flex;
  justify-content: flex-end;
}

/* 球桌列表 */
.table-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  background: #f5f5f5;
}

/* 球桌卡片 */
.table-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.table-card.batch-mode {
  background: #f8f8f8;
}

/* 选择框 */
.checkbox-container {
  margin-right: 16rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.checkbox.checked {
  background: #1890ff;
  border-color: #1890ff;
}

.checkmark {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 卡片左侧内容 */
.card-left {
  flex: 1;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.table-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.info-tag {
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.divider {
  color: #e5e5e5;
  font-size: 24rpx;
}

/* 卡片右侧内容 */
.card-right {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

/* 状态选择器 */
.status-picker {
  background: #f8f8f8;
  border: 1rpx solid #e5e5e5;
  border-radius: 6rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #666;
}

.status-inline {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-bg-available {
  background: #52c41a;
}

.status-bg-in_use {
  background: #faad14;
}

.status-bg-reserved {
  background: #1890ff;
}

.status-bg-fault {
  background: #ff4d4f;
}

.status-text-inline {
  font-size: 24rpx;
  color: #666;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 12rpx;
}

.mini-btn {
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  border: 1rpx solid;
}

.btn-edit {
  color: #1890ff;
  border-color: #1890ff;
  background: #fff;
}

.btn-delete {
  color: #ff4d4f;
  border-color: #ff4d4f;
  background: #fff;
}

.mini-btn:active {
  transform: scale(0.95);
}

/* 空态处理 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-text {
  margin-bottom: 16rpx;
}

/* 提示信息 */
.hint {
  display: block;
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
  border-radius: 8rpx;
  padding: 16rpx;
  margin: 20rpx;
  font-size: 24rpx;
  color: #ff4d4f;
  text-align: center;
}

/* 新增球桌按钮 */
.add-btn-pill {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  background: #1890ff;
  color: #fff;
  padding: 20rpx 32rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.3);
  display: flex;
  align-items: center;
  gap: 8rpx;
  z-index: 100;
}

.add-icon {
  font-size: 32rpx;
  font-weight: bold;
}

.add-btn-pill:active {
  transform: scale(0.95);
}