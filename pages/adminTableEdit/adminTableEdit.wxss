.page-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: #f7f7f7;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  padding: 40rpx;
  width: 90%;
  max-width: 700rpx;
  box-sizing: border-box;
}

.text-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 40rpx;
  color: #0a72ec;
  text-align: center;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.value {
  display: block;
  font-size: 30rpx;
  color: #333;
  padding: 18rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.input {
  display: block;
  width: 100%;
  box-sizing: border-box;
  font-size: 30rpx;
  padding: 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  background: #fff;
  transition: all 0.3s;
}

.input:focus {
  border-color: #1677ff;
}

.picker-container {
  width: 100%;
}

.picker-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
}

.picker-value {
  font-size: 30rpx;
  color: #333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

.actions {
  display: flex;
  gap: 24rpx;
  margin-top: 50rpx;
}

.btn-primary {
  flex: 1;
  background: #1677ff;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-secondary {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  text-align: center;
  line-height: 1.5;
}
