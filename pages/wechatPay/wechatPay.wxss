page {
  background-color: #07c160;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  height: 100vh;
  overflow: hidden;
}

.page-container {
  background: linear-gradient(180deg, #07c160 0%, #07c160 30%, #f5f5f5 30%, #f5f5f5 100%);
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 微信支付头部 */
.pay-header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  color: #fff;
}

.pay-logo {
  margin-bottom: 30rpx;
}

.logo-text {
  font-size: 36rpx;
  font-weight: 600;
}

.pay-amount {
  margin-bottom: 20rpx;
}

.amount-symbol {
  font-size: 48rpx;
  font-weight: 300;
}

.amount-number {
  font-size: 64rpx;
  font-weight: 600;
}

.pay-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 支付信息 */
.pay-info {
  background: #fff;
  margin: 0 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 支付方式选择 */
.payment-methods {
  display: flex;
  gap: 20rpx;
}

.payment-method {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  cursor: pointer;
  transition: all 0.3s;
}

.payment-method.active {
  border-color: #07c160;
  background-color: #e6f7ed;
}

.payment-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.payment-method text {
  font-size: 24rpx;
  color: #666;
}

.payment-method.active text {
  color: #07c160;
  font-weight: 500;
}

/* 支付状态 */
.pay-status {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.status-icon {
  margin-bottom: 30rpx;
}

.icon-text {
  font-size: 80rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.countdown {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 500;
}

.success-desc,
.failed-desc {
  font-size: 28rpx;
  color: #666;
}

/* 支付按钮 */
.pay-actions {
  padding: 40rpx;
}

.pay-btn {
  background: #07c160;
  color: #fff;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  transition: all 0.3s;
}

.pay-btn.loading {
  background: #b2e4c5;
}

.pay-btn:active {
  background: #06a952;
  transform: scale(0.98);
}

.cancel-btn {
  background: transparent;
  color: #07c160;
  height: 88rpx;
  border: 2rpx solid #07c160;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.cancel-btn:active {
  background: rgba(7, 193, 96, 0.1);
}

/* 重试按钮 */
.retry-actions {
  width: 100%;
  max-width: 400rpx;
  margin-top: 40rpx;
}

.retry-btn {
  background: #ff6b35;
  color: #fff;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  transition: all 0.3s;
}

.retry-btn:active {
  background: #e55a2b;
  transform: scale(0.98);
}

/* 安全提示 */
.security-tips {
  background: #f8f8f8;
  margin: 20rpx 30rpx 40rpx;
  border-radius: 12rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tips-content text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

/* 成功状态 */
.pay-status.success .status-text {
  color: #07c160;
}

/* 失败状态 */
.pay-status.failed .status-text {
  color: #ff6b35;
}