<view class="page-container">
  <scroll-view class="scrollarea" scroll-y refresher-enabled="true" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    
    <!-- 顶部用户信息卡片 -->
    <view class="user-card">
      <view class="user-info-section">
        <text class="user-display">{{user.name || user.account || '未登录'}}</text>
        <text class="user-account">{{user.account ? '账号：' + user.account : '请先登录'}}</text>
      </view>
      
      <view class="balance-section">
        <text class="balance-amount">￥{{walletBalanceText}}</text>
        <view class="balance-actions">
          <button class="recharge-btn" bindtap="goWallet">立即充值</button>
        </view>
      </view>
    </view>
    
    <!-- 功能模块区域 -->
    <view class="function-section">
      <view class="section-title">我的服务</view>
      <view class="function-grid">
        <view class="function-item" bindtap="goReservations">
          <view class="item-icon reservation-icon"></view>
          <text class="item-title">预约记录</text>
        </view>
        
        <view class="function-item" bindtap="goSessions">
          <view class="item-icon session-icon"></view>
          <text class="item-title">进行中订单</text>
        </view>
        
        <view class="function-item" bindtap="goConsumptions">
          <view class="item-icon consumption-icon"></view>
          <text class="item-title">消费记录</text>
        </view>
      </view>
    </view>
    
    <!-- 底部操作区域 -->
    <view class="actions-section">
      <view class="action-buttons">
        <button class="action-btn edit-profile-btn" bindtap="editProfile">修改资料</button>
        <button class="action-btn logout-btn" bindtap="logout">退出登录</button>
        <button class="action-btn delete-btn" bindtap="deleteAccount">注销账号</button>
      </view>
    </view>
    
  </scroll-view>
</view>