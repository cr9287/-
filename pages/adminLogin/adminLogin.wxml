<view class="page-container">
  <view class="top-header">
    <view class="title">管理员登录</view>
    <view class="subtitle">请使用管理员账号登录后台系统</view>
  </view>

  <view class="card">
    <!-- 账号输入 -->
    <view class="form-item">
      <view class="form-label">
        <text>管理员账号</text>
      </view>
      <input class="form-input" type="text" placeholder="请输入管理员账号" placeholder-class="input-placeholder" value="{{account}}" bindinput="onAccount" />
    </view>
    
    <!-- 密码输入 -->
    <view class="form-item">
      <view class="form-label">
        <text>密码</text>
      </view>
      <view class="input-wrapper">
        <input class="form-input" password="{{!passwordVisible}}" placeholder="请输入密码" placeholder-class="input-placeholder" value="{{pwd}}" bindinput="onPwd" />
        <view class="password-toggle" bindtap="togglePasswordVisibility">
          {{passwordVisible ? '隐藏' : '显示'}}
        </view>
      </view>
    </view>
    
    <!-- 登录按钮 -->
    <view class="mt-40">
      <button class="btn-primary" bindtap="login" loading="{{loading}}" disabled="{{loading}}">登录后台</button>
    </view>
    
    <!-- 底部链接 -->
    <view class="link-section" style="justify-content: center;">
      <navigator url="/pages/userLogin/userLogin" open-type="redirect" class="link-text">返回用户登录</navigator>
    </view>
  </view>
</view>
