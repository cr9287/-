/* pages/adminAdmins/adminAdmins.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 0;
}

/* 页面容器 */
.page-container {
  padding: 0;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 页面头部 */
.page-header-row {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.page-subtitle {
  font-size: 26rpx;
  color: #666;
}

/* 右上角新建按钮 */
.header-right {
  display: flex;
  align-items: center;
}

.add-btn {
  background-color: #1890ff;
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  border: none;
}

.add-btn::after {
  border: none;
}

/* 管理员列表 */
.admin-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  background: #f5f5f5;
}

/* 管理员卡片 */
.admin-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #f0f0f0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

/* 卡片左侧内容 */
.card-left {
  flex: 0 0 auto;
  min-width: 0;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: nowrap;
}

.admin-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
}

.info-tag {
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  white-space: nowrap;
}

.divider {
  color: #e5e5e5;
  font-size: 24rpx;
}

/* 卡片右侧操作按钮 */
.card-right {
  flex: 0 0 auto;
  margin-left: 16rpx;
}

.action-buttons {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
}

.mini-btn {
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  border: 1rpx solid;
  display: inline-block;
  line-height: 1.4;
  white-space: nowrap;
}

.btn-edit {
  color: #1890ff;
  border-color: #1890ff;
  background: #fff;
}

.btn-demote {
  color: #fa8c16;
  border-color: #fa8c16;
  background: #fff;
}

.btn-delete {
  color: #ff4d4f;
  border-color: #ff4d4f;
  background: #fff;
}

.mini-btn::after {
  border: none;
}

.mini-btn:active {
  transform: scale(0.95);
}

/* 空态处理 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-text {
  margin-bottom: 16rpx;
}
