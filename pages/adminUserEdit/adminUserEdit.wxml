<view class="page-wrap">
  <view class="card">
    <view class="text-title">编辑用户</view>
    
    <view class="form-item">
      <text class="label">账号</text>
      <text class="value">{{account}}</text>
    </view>
    
    <view class="form-item">
      <view class="label">用户名</view>
      <input class="input" placeholder="请输入用户名" value="{{username}}" bindinput="onUsername" />
    </view>
    
    <view class="form-item">
      <view class="label">手机号</view>
      <input class="input" type="number" placeholder="请输入手机号（选填）" value="{{phone}}" bindinput="onPhone" />
    </view>
    
    <view class="form-item">
      <view class="label">新密码</view>
      <view class="input-wrapper">
        <input class="input" password="{{!passwordVisible}}" placeholder="留空则不修改" value="{{password}}" bindinput="onPassword" />
        <view class="eye-icon" bindtap="togglePasswordVisibility">
          {{passwordVisible ? '隐藏' : '显示'}}
        </view>
      </view>
    </view>
    
    <view class="actions">
      <button class="btn-primary" bindtap="save">保存</button>
      <button class="btn-secondary" bindtap="cancel">取消</button>
    </view>
  </view>
</view>
