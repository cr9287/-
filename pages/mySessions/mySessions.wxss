/* 引入全局样式 */
@import "../../styles/global.wxss";

/* 骨架屏样式 */
.skeleton {
  padding: var(--space-xl);
}

.skeleton-header {
  margin-bottom: var(--space-xl);
}

.skeleton-title {
  height: 32rpx;
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 50%, #f2f2f2 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 8rpx;
  margin-bottom: var(--space-md);
}

.skeleton-subtitle {
  height: 24rpx;
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 50%, #f2f2f2 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 6rpx;
  width: 60%;
}

.skeleton-item {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-xl);
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 50%, #f2f2f2 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 40rpx;
  margin-right: var(--space-lg);
}

.skeleton-content {
  flex: 1;
}

.skeleton-line {
  height: 24rpx;
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 50%, #f2f2f2 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 6rpx;
  margin-bottom: var(--space-md);
}

.skeleton-line.short {
  width: 70%;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

.loading-container {
  padding: var(--space-xl);
}

.sessions-page {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 订单列表 */
.flex-column {
  flex: 1;
  overflow-y: auto;
  padding: var(--space-lg);
  background: var(--bg-color);
}

.gap-20 {
  gap: var(--space-lg);
}

/* 订单卡片 */
.card {
  composes: card;
  padding: var(--space-xl);
  cursor: pointer;
}

.card:active {
  transform: scale(0.98);
  background: #f8f8f8;
}

.p-30 {
  padding: var(--space-2xl);
}

.mb-0 {
  margin-bottom: 0;
}

.mb-20 {
  margin-bottom: var(--space-lg);
}

.pb-20 {
  padding-bottom: var(--space-lg);
}

.pt-20 {
  padding-top: var(--space-lg);
}

/* 卡片头部 */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-lg {
  font-size: var(--text-lg);
}

.text-bold {
  font-weight: var(--font-semibold);
}

.text-primary {
  color: var(--text-primary);
}

/* 标签样式 */
.tag {
  composes: tag;
}

.tag-primary {
  composes: tag-primary;
}

/* 订单时间区域 */
.flex-start {
  display: flex;
  align-items: flex-start;
}

.gap-10 {
  gap: var(--space-sm);
}

.text-sub {
  font-size: var(--text-xs);
  color: var(--text-muted);
}

/* 操作按钮 */
.btn {
  composes: btn;
  width: 100%;
  height: 80rpx;
}

.btn-primary {
  composes: btn-primary;
}

/* 页面底部统计 */
.page-footer {
  background: var(--card-bg);
  padding: var(--space-lg);
  border-top: 1rpx solid var(--border-color);
  text-align: center;
}

.stat-item {
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

/* 空状态页面 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
  background: #f5f5f5;
  height: 100vh;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon::before {
  content: "";
  font-size: 48rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.empty-btn {
  background: #1677ff;
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-btn:active {
  background: #0958d9;
}

/* 进行中订单卡片 */
.session-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s ease;
}

.session-card:active {
  transform: scale(0.98);
  background: #f8f9fa;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.session-table {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.session-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

/* 卡片主体 */
.card-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.time-label {
  font-size: 24rpx;
  color: #666;
}

.session-time {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

/* 底部操作按钮 */
.card-footer {
  display: flex;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-settle {
  flex: 1;
  height: 64rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #1677ff;
  color: white;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-settle:active {
  background: #0958d9;
}

/* 边框样式 */
.border-bottom {
  border-bottom: 1rpx solid var(--border-light);
}

.border-top {
  border-top: 1rpx solid var(--border-light);
}