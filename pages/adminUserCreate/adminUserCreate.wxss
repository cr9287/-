.page-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: #f7f7f7;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  padding: 40rpx;
  width: 90%;
  max-width: 700rpx;
  box-sizing: border-box;
}

.text-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 40rpx;
  color: #0a72ec;
  text-align: center;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input {
  display: block;
  width: 100%;
  box-sizing: border-box;
  font-size: 30rpx;
  padding: 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  background: #fff;
  transition: all 0.3s;
}

.input:focus {
  border-color: #1677ff;
}

.actions {
  display: flex;
  gap: 24rpx;
  margin-top: 50rpx;
}

.btn-primary {
  flex: 1;
  background: #1677ff;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  text-align: center;
  line-height: 1.5;
}

/* Specific Styles */
.input-wrapper {
  position: relative;
}

.input-wrapper .input {
  padding-right: 80rpx;
}

.eye-icon {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  font-size: 26rpx;
  color: #576b95;
  padding: 10rpx;
}
