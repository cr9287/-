/* 统一登录注册页面样式 */

/* 页面容器 */
.page-container {
  padding: 40rpx 32rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

/* 系统标题 */
.system-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0 20rpx 0;
  margin-bottom: 0;
}

.system-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  text-align: center;
  letter-spacing: 1rpx;
}

/* 顶部标题 */
.top-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 卡片容器 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
}

/* 表单样式 */
.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
  pointer-events: none; /* 防止标签干扰输入框点击 */
}

.required {
  color: #ff4d4f;
  margin-left: 8rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  background: #f9f9f9;
  border: 2rpx solid #e6e6e6;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  transition: all 0.3s;
  position: relative;
  z-index: 1; /* 确保输入框在正确层级 */
}

.form-input:focus {
  background: #fff;
  border-color: #1677ff;
  box-shadow: 0 0 0 2rpx rgba(22, 119, 255, 0.1);
}

.input-placeholder {
  color: #bbbbbb;
}

/* 密码输入框容器 */
.input-wrapper {
  position: relative;
  width: 100%;
}

.input-wrapper .form-input {
  padding-right: 90rpx;
}

.password-toggle {
  position: absolute;
  right: 0;
  top: 0;
  height: 88rpx;
  width: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5; /* 降低层级，确保输入框优先 */
  font-size: 26rpx;
  color: #576b95;
  pointer-events: auto; /* 确保切换按钮本身可点击 */
}

/* 按钮 */
.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx; /* 胶囊型按钮 */
  border: none;
  padding: 0;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: translateY(2rpx);
}

.btn-primary[disabled] {
  background: #f0f0f0;
  color: #ccc;
  box-shadow: none;
}

/* 链接区域 */
.link-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 30rpx;
  padding: 0 10rpx;
}

.link-text {
  font-size: 26rpx;
  color: #576b95;
}

.text-center {
  text-align: center;
}

.mt-40 { margin-top: 40rpx; }
.mb-40 { margin-bottom: 40rpx; }

/* 账号选择器特殊样式 */
.account-picker {
  background: #e6f7ff;
  border: 2rpx solid #91d5ff;
  color: #1677ff;
  padding: 20rpx;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
  color: #ccc;
  font-size: 24rpx;
}

.divider::before, .divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #eee;
}

.divider::before { margin-right: 20rpx; }
.divider::after { margin-left: 20rpx; }
