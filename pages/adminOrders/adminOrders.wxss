page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 0;
}

/* 页面容器 */
.page-container {
  padding: 0;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 顶部导航栏 */
.nav-bar {
  background: #fff;
  padding: 0 20rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e5e5e5;
  position: relative;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}

.nav-title {
  flex: 1;
  text-align: center;
}

.title-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder {
  width: 60rpx;
}

/* 标签筛选栏 */
.tab-bar {
  background: #fff;
  display: flex;
  border-bottom: 1rpx solid #e5e5e5;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.tab.active {
  color: #1890ff;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

/* 筛选条件区域 */
.filter-section {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.search-input {
  flex: 1;
  min-width: 200rpx;
  background: #f8f8f8;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  font-size: 28rpx;
}

.date-picker {
  font-size: 26rpx;
  color: #666;
  background: #f8f8f8;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e5e5e5;
  min-width: 160rpx;
}

.clear-btn {
  background: #f0f0f0;
  color: #666;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  border: 1rpx solid #ddd;
}

/* 操作按钮区域 */
.action-section {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.action-btns {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.action-btn.recharge-btn {
  background: #52c41a;
  color: #fff;
  border: 1rpx solid #52c41a;
}

.action-btn.batch-btn {
  background: #1890ff;
  color: #fff;
  border: 1rpx solid #1890ff;
}

.action-btn:active {
  transform: scale(0.95);
}

/* 批量操作区域 */
.batch-section {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.batch-info {
  flex: 1;
}

.batch-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.select-all-btn {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.delete-btn {
  background: #ff4d4f;
  color: #fff;
  border: 1rpx solid #ff4d4f;
}

.delete-btn.disabled {
  background: #f5f5f5;
  color: #ccc;
  border: 1rpx solid #ddd;
  cursor: not-allowed;
}

.delete-btn.disabled:active {
  transform: none;
}

.cancel-btn {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.batch-action-btn:active {
  transform: scale(0.95);
}

/* 订单列表 */
.order-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  background: #f5f5f5;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #f0f0f0;
}

.order-card.batch-mode {
  background: #f8f8f8;
}

/* 选择框 */
.checkbox-container {
  margin-bottom: 16rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.checkbox.checked {
  background: #1890ff;
  border-color: #1890ff;
}

.checkmark {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 卡片行布局 */
.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-row:last-child {
  margin-bottom: 0;
}

.row-left {
  flex: 1;
}

.row-right {
  text-align: right;
}

/* 第一行：球桌与时间 */
.table-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.time-text {
  font-size: 26rpx;
  color: #999;
}

/* 第二行：用户信息 */
.user-text, .phone-text {
  font-size: 26rpx;
  color: #666;
}

/* 第三行：状态与金额 */
.status-text {
  font-size: 26rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  display: inline-block;
}

.status-pending { color: #ff4d4f; background: rgba(255, 77, 79, 0.1); }
.status-active { color: #faad14; background: rgba(250, 173, 20, 0.1); }
.status-completed { color: #52c41a; background: rgba(82, 196, 26, 0.1); }
.status-paid { color: #52c41a; background: rgba(82, 196, 26, 0.1); }
.status-reserved { color: #1890ff; background: rgba(24, 144, 255, 0.1); }
.status-verified { color: #52c41a; background: rgba(82, 196, 26, 0.1); }
.status-cancelled { color: #8c8c8c; background: rgba(140, 140, 140, 0.1); }
.status-expired { color: #8c8c8c; background: rgba(140, 140, 140, 0.1); }

.cancelled-tag {
  color: #8c8c8c;
  background: rgba(140, 140, 140, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.amount-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff6b35;
}

/* 第四行：操作按钮 */
.action-buttons {
  display: flex;
  gap: 12rpx;
  justify-content: flex-start;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  border: 1rpx solid;
}

.action-btn.edit-btn {
  color: #1890ff;
  border-color: #1890ff;
  background: #fff;
}

.action-btn.delete-btn {
  color: #ff4d4f;
  border-color: #ff4d4f;
  background: #fff;
}

.action-btn:active {
  transform: scale(0.95);
}

/* 空态处理 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-text {
  color: #666;
  font-size: 32rpx;
  font-weight: 500;
}

.empty-hint {
  color: #999;
  font-size: 26rpx;
  max-width: 400rpx;
  line-height: 1.5;
}

/* 充值弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-container {
  background: #fff;
  border-radius: 12rpx;
  width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #e5e5e5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
}

.modal-content {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-select, .form-input {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  background: #fff;
}

.picker-text {
  color: #666;
}

.modal-footer {
  padding: 30rpx;
  border-top: 1rpx solid #e5e5e5;
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  cursor: pointer;
}

.modal-btn.cancel {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.modal-btn.confirm {
  background: #1890ff;
  color: #fff;
  border: 1rpx solid #1890ff;
}

/* 充值弹窗样式 */
.recharge-modal .modal-container {
  width: 90%;
  max-width: 700rpx;
}

/* 用户余额显示 */
.user-balance {
  margin-top: 12rpx;
  padding: 12rpx;
  background: #f0f7ff;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #1890ff;
}

/* 快捷金额按钮 */
.quick-amounts {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.quick-amount-btn {
  flex: 1;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.quick-amount-btn.active {
  background: #e6f7ff;
  border-color: #1890ff;
  color: #1890ff;
  font-weight: 500;
}

/* 充值金额输入框 */
.recharge-input {
  height: 80rpx;
  font-size: 32rpx;
}

/* 金额错误提示 */
.amount-error {
  margin-top: 12rpx;
  color: #ff4d4f;
  font-size: 24rpx;
}

/* 支付方式单选样式 */
.method-radio {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.radio-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: transparent;
  transition: all 0.3s;
}

.radio-dot.active {
  background: #1890ff;
}

.payment-method.active .method-radio {
  border-color: #1890ff;
}

/* 禁用按钮 */
.modal-btn.disabled {
  opacity: 0.5;
  cursor: not-allowed;
}