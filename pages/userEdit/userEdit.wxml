<view class="user-edit-page">

  <!-- 用户信息表单 -->
  <form bindsubmit="submitForm" class="edit-form">
    <!-- 基础信息区 -->
    <view class="section basic-info">
      <view class="section-title">基础信息</view>
      
      <!-- 用户名 -->
      <view class="form-item">
        <view class="form-label">用户名</view>
        <view class="form-input-wrapper">
          <input 
            class="form-input" 
            name="account" 
            value="{{user.account}}" 
            disabled
            placeholder=""
          />
          <view class="input-hint">不可修改</view>
        </view>
      </view>

      <!-- 昵称 -->
      <view class="form-item">
        <view class="form-label">昵称</view>
        <view class="form-input-wrapper">
          <input 
            class="form-input" 
            data-name="name" 
            placeholder="请输入昵称" 
            value="{{formData.name}}"
            bindinput="onInputChange"
          />
          <view class="input-hint">选填</view>
        </view>
      </view>

      <!-- 手机号 -->
      <view class="form-item">
        <view class="form-label">手机号</view>
        <view class="form-input-wrapper">
          <input 
            class="form-input" 
            data-name="phone" 
            placeholder="请输入手机号" 
            value="{{formData.phone}}"
            type="number"
            maxlength="11"
            bindinput="onInputChange"
          />
          <view class="input-hint">选填</view>
        </view>
        <view class="error-tip" wx:if="{{errors.phone}}">{{errors.phone}}</view>
      </view>
    </view>
    
    <!-- 密码管理区 -->
    <view class="section password-info">
      <view class="section-title">密码管理</view>
      
      <!-- 修改密码开关 -->
      <view class="password-switch">
        <view class="switch-label">修改密码</view>
        <switch 
          checked="{{showPasswordForm}}" 
          bindchange="togglePasswordForm"
        />
      </view>
      
      <!-- 当前密码 -->
      <view class="form-item" wx:if="{{showPasswordForm}}">
        <view class="form-label">当前密码</view>
        <view class="form-input-wrapper">
          <input 
            class="form-input" 
            data-name="currentPassword" 
            placeholder="请输入当前密码" 
            password="{{!currentPasswordVisible}}"
            bindinput="onInputChange"
            value="{{formData.currentPassword}}"
            style="padding-right: 80rpx;"
          />
          <view class="eye-icon" bindtap="toggleCurrentPasswordVisibility" style="position: absolute; right: 20rpx; top: 50%; transform: translateY(-50%); z-index: 10; font-size: 26rpx; color: #576b95;">
            {{currentPasswordVisible ? '隐藏' : '显示'}}
          </view>
        </view>
        <view class="error-tip" wx:if="{{errors.currentPassword}}">{{errors.currentPassword}}</view>
      </view>

      <!-- 新密码 -->
      <view class="form-item" wx:if="{{showPasswordForm}}">
        <view class="form-label">新密码</view>
        <view class="form-input-wrapper">
          <input 
            class="form-input" 
            data-name="newPassword" 
            placeholder="请输入新密码" 
            password="{{!newPasswordVisible}}"
            bindinput="onInputChange"
            value="{{formData.newPassword}}"
            style="padding-right: 80rpx;"
          />
          <view class="eye-icon" bindtap="toggleNewPasswordVisibility" style="position: absolute; right: 20rpx; top: 50%; transform: translateY(-50%); z-index: 10; font-size: 26rpx; color: #576b95;">
            {{newPasswordVisible ? '隐藏' : '显示'}}
          </view>
        </view>
        <view class="error-tip" wx:if="{{errors.newPassword}}">{{errors.newPassword}}</view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <button 
      form-type="submit" 
      class="submit-btn"
      loading="{{submitting}}"
      disabled="{{!canSubmit}}"
    >
      保存修改
    </button>
  </form>
</view>