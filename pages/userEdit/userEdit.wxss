/** 用户修改资料页面样式 **/
.user-edit-page {
  background-color: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部标题栏 */
.page-header {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  color: white;
  padding: 30rpx 24rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  flex: 1;
  position: absolute;
  left: 0;
  right: 0;
  top: 30rpx;
  pointer-events: none;
}

.header-back {
  font-size: 28rpx;
  z-index: 10;
  padding: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

/* 表单样式 */
.edit-form {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

/* 区块样式 */
.section {
  padding: 30rpx 24rpx;
}

/* 基础信息区 */
.basic-info {
  background-color: #fafafa;
}

/* 密码管理区 */
.password-info {
  background-color: #ffffff;
  border-top: 2rpx solid #e8e8e8;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1677ff;
  margin-bottom: 24rpx;
  display: block;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

/* 输入框容器 */
.form-input-wrapper {
  position: relative;
  width: 100%;
}

/* 输入框样式 */
.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 0 20rpx 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #ffffff;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #1677ff;
  box-shadow: 0 0 0 4rpx rgba(22, 119, 255, 0.1);
}

.form-input:disabled {
  background: #f5f5f5;
  color: #999;
}

/* 输入框提示（选填、不可修改等） */
.input-hint {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #999;
  pointer-events: none;
}

/* 错误提示 */
.error-tip {
  font-size: 24rpx;
  /* color: #ff4d4f; */
  margin-top: 8rpx;
  text-align: left;
}

/* 修改密码开关 */
.password-switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 0 24rpx 0;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.switch-label {
  font-size: 30rpx;
  color: #333;
}

/* 提交按钮 */
.submit-btn {
  width: 90%;
  height: 90rpx;
  background: #36B37E;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  margin: 30rpx auto 40rpx;
  border: none;
  display: block;
  transition: all 0.3s ease;
}

.submit-btn:disabled {
  background: #F0F0F0;
  color: #999999;
}

.submit-btn:active:not(:disabled) {
  transform: scale(0.98);
  background: #2DA06B;
}
