/* 登录页面样式 - 微信原生风格 */

/* 页面容器 */
.page-container {
  padding: 40rpx 32rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 顶部标题 */
.top-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  padding-top: 40rpx;
}

.title-section {
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
}

/* 卡片容器 */
.login-card {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  padding: 32rpx;
  margin-bottom: 32rpx;
}

/* 分割线 */
.divider-line {
  height: 1rpx;
  background: #eeeeee;
  margin: 20rpx 0;
}

.text-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

/* 表单样式 */
.form-item {
  margin-bottom: 32rpx;
  text-align: left;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.required {
  color: #f5222d;
  font-size: 32rpx;
}

.form-input {
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

/* 操作按钮 */
.actions {
  margin-top: 32rpx;
}

.login-btn {
  width: 100%;
  background: #1677ff;
  color: white;
  border-radius: 8rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 500;
}

/* 辅助链接区 */
.footer-section {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
  margin-top: 32rpx;
}

.footer-link {
  margin: 0 16rpx;
  color: #1677ff;
  font-size: 26rpx;
}

/* 密码显隐切换 */
.input-wrapper {
  position: relative;
  width: 100%;
}

.password-toggle {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  padding: 10rpx;
  font-size: 26rpx;
  color: #576b95;
}

.input-wrapper .form-input {
  padding-right: 90rpx;
}
